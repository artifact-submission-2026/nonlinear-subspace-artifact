      "eq11 = 158590508*t10*t11*t12 + 928740774*t12^3 - 517381167*t10*t11*t13 + 362654304*t10*t12*t13 + 986099714*t11*t12*t13 - 244732617*t12^2*t13 - 1016612633*t10*t13^2 + 678338748*t11*t13^2 + 320433265*t12*t13^2 - 372042403*t13^3\n",
      "eq12 = 79295254*t10*t12^2 + 997108016*t12^3 - 517381167*t10*t12*t13 - 867648212*t12^2*t13 + 585891190*t10*t13^2 - 42162830*t12*t13^2 + 294673989*t13^3\n",
      "eq13 = 736667229*t11^3 - 810425871*t12^3 + 181327152*t11^2*t13 - 499886802*t12^2*t13 + 834841506*t11*t13^2 + 980822420*t12*t13^2 + 113456611*t13^3\n",
      "eq14 = 79295254*t11^2*t12 - 883116024*t12^3 + 806662633*t11^2*t13 + 362654304*t11*t12*t13 - 88107975*t12^2*t13 - 1016612633*t11*t13^2 - 688007931*t12*t13^2 + 827818816*t13^3\n",
      "eq15 = 79295254*t11*t12^2 + 512299092*t12^3 - 517381167*t11*t12*t13 - 822127364*t12^2*t13 + 585891190*t11*t13^2 - 762670254*t12*t13^2 + 809503523*t13^3\n",
