      "eq6 = 663799416*t12^3 + 528613989*t12^2*t13 + 688398256*t12*t13^2 + 767619578*t13^3 + 79295254*t12^2*t14 - 517381167*t12*t13*t14 + 585891190*t13^2*t14 - 1055586276*t12^2 - 720709979*t12*t13 - 406969071*t13^2\n",
