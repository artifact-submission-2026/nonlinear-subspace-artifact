      "eq8 = 79295254*t10^2*t11 + 223434060*t12^3 + 181327152*t10^2*t13 + 986099714*t10*t11*t13 + 650867118*t12^2*t13 + 1035196189*t10*t13^2 - 1000107070*t11*t13^2 - 585736449*t12*t13^2 + 326301109*t13^3\n",
